post_install() {
    systemctl --global enable odoo-companion.service >/dev/null 2>&1 || true
    gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor >/dev/null 2>&1 || true
    update-desktop-database -q /usr/share/applications >/dev/null 2>&1 || true
    echo ">>> Log out and back in (or: systemctl --user enable --now odoo-companion.service)"
}

post_upgrade() {
    post_install
}

pre_remove() {
    systemctl --global disable odoo-companion.service >/dev/null 2>&1 || true
}
